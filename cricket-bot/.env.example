# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Database URL
# SQLite (default for development):
DATABASE_URL=sqlite:///./cricket_bot.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/cricket_bot

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Admin panel port (default: 5000)
ADMIN_PORT=5000

# Secret key for Flask sessions (generate a strong random value for production)
ADMIN_SECRET_KEY=change-me-in-production

# Admin panel credentials (HTTP Basic Auth)
# Leave ADMIN_PASSWORD empty to disable auth (development only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Telegram admin user IDs (comma-separated) – for /addplayer, /editplayer, etc.
ADMIN_TELEGRAM_IDS=

# Telegram Mini App admin panel
# URL where the Mini App is served (e.g. https://your-app.onrender.com/miniapp)
MINIAPP_URL=
# JWT secret for Mini App auth tokens (defaults to ADMIN_SECRET_KEY if unset)
MINIAPP_JWT_SECRET=
# Initial admin email/password – auto-created on first run if admin_users table is empty
MINIAPP_INIT_EMAIL=admin@example.com
MINIAPP_INIT_PASSWORD=changeme
